{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "moduleResolution": "node",

    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "types": [
      "node"
    ]
  },

  "include": [
    "src"
  ],

  "exclude": [
    "node_modules"
  ]
}